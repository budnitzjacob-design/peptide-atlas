generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  role          Role     @default(READER)
  status        UserStatus @default(ACTIVE)
  accounts      Account[]
  sessions      Session[]
  moderatorProfile ModeratorProfile?
  verifications CitationVerification[]
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ModeratorProfile {
  id                  String @id @default(cuid())
  userId              String @unique
  displayName          String
  expertiseTags        String[]
  canVerifyCitation    Boolean @default(false)
  canResolveConflict   Boolean @default(false)
  canPublishData       Boolean @default(false)
  verificationCount    Int @default(0)
  notes                String?
  user                 User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Peptide {
  id          String @id
  primaryName String
  aliases     String[]
  category    String
  evidenceTier String
  regulatoryStatus String
  data        Json
  claims      Claim[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Citation {
  id          String @id
  sourceType  String
  title       String
  authors     String[]
  year        Int?
  pmid        String?
  doi         String?
  url         String
  accessedAt  DateTime?
  quality     String
  notes       String?
  verifications CitationVerification[]
}

model Claim {
  id          String @id
  peptideId   String
  field       String
  value       String @db.Text
  species     String
  context     String
  symbols     String[]
  confidence  Float
  citationIds String[]
  needsModeratorReview Boolean @default(true)
  peptide     Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model CitationVerification {
  id          String @id @default(cuid())
  citationId  String
  peptideId   String
  claimIds    String[]
  reviewerId  String
  status      VerificationStatus @default(DRAFT)
  verdict     String
  sourceQualityScore Int
  verificationWriteup String @db.Text
  limitations String? @db.Text
  checkedValues Json
  citation    Citation @relation(fields: [citationId], references: [id], onDelete: Cascade)
  reviewer    User @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String @id @default(cuid())
  actorId   String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  actor      User? @relation(fields: [actorId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  READER
  MODERATOR
  SENIOR_MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum VerificationStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  NEEDS_CHANGES
  REJECTED
  SUPERSEDED
}
